# MathIQ frontend env vars
# Copy to .env (gitignored) and adjust for your environment.

# URL of the MathIQ worker backend.
# Local dev:        http://localhost:8787
# Production deploy: https://<your-worker-name>.<account>.workers.dev
VITE_WORKER_URL=http://localhost:8787

# Clerk publishable key (safe to expose — client-visible by design).
# Get at: https://dashboard.clerk.com → API Keys → Quick Copy → Frontend
# Test key looks like: pk_test_aGFwcHkubWFudHJhLTQ5LmNsZXJrLmFjY291bnRzLmRldiQ
VITE_CLERK_PUBLISHABLE_KEY=
